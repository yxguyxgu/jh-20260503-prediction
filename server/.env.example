# PostgreSQL (Vercel Storage → Postgres, or Neon, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

JWT_SECRET="replace-with-long-random-string"
PORT=4000
ADMIN_PASSWORD="change-for-seed"

# REST routes are under /api (e.g. POST /api/login). Same on Vercel + Postgres.
