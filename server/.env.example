# PostgreSQL. Vercel: Project → Storage → Postgres → copy URL (use direct / non-pooling for this API).
# Example local: postgresql://postgres:postgres@localhost:5432/prediction?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

JWT_SECRET="replace-with-long-random-string"
PORT=4000
ADMIN_PASSWORD="change-for-seed"
